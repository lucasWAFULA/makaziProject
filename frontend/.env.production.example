# Copy to .env.production before building for production.
# Option A: Firebase Hosting rewrites /api/** to Cloud Run.
VITE_API_URL=/api

# Option B: call Cloud Run or a custom API domain directly.
# VITE_API_URL=https://karibumakazi-api-xxxxx.a.run.app/api
# VITE_API_URL=https://api.yourdomain.com/api
