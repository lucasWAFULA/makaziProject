{
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "karibumakazi-api",
          "region": "europe-west1"
        }
      },
      {
        "source": "/admin/**",
        "run": {
          "serviceId": "karibumakazi-api",
          "region": "europe-west1"
        }
      },
      {
        "source": "/static/**",
        "run": {
          "serviceId": "karibumakazi-api",
          "region": "europe-west1"
        }
      },
      {
        "source": "/media/**",
        "run": {
          "serviceId": "karibumakazi-api",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|webp|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
