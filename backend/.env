DEBUG=True
SECRET_KEY=your-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
# PostgreSQL (replace with your user, password, and database name)
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/DATABASE

# Example: user kusajilisha, password mypass, database kusajilisha
# DATABASE_URL=postgres://kusajilisha:mypass@localhost:5432/kusajilisha

# Redis (optional; leave empty to disable)
REDIS_URL=

# Production (when using HTTPS behind nginx)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

USE_S3=False
MEDIA_ROOT=media

MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_BASE_URL=https://yourdomain.com
