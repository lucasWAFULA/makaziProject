DEBUG=False
SECURE_SSL_REDIRECT=True
SECRET_KEY=use-secret-manager-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,karibumakazi-api-xxxxx.a.run.app
DATABASE_URL=postgres://DB_USER:DB_PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:europe-west1:INSTANCE_NAME
REDIS_URL=

CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://karibumakazi-api-xxxxx.a.run.app

USE_GCS=True
GS_BUCKET_NAME=PROJECT_ID-karibumakazi-media
GS_PROJECT_ID=PROJECT_ID
GS_DEFAULT_ACL=
GS_QUERYSTRING_AUTH=False

MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=use-secret-manager
MPESA_CONSUMER_SECRET=use-secret-manager
MPESA_PASSKEY=use-secret-manager
MPESA_SHORTCODE=
MPESA_CALLBACK_BASE_URL=https://karibumakazi-api-xxxxx.a.run.app

OPENAI_API_KEY=use-secret-manager
OPENAI_MODEL=gpt-4o-mini
AI_ASSISTANT_NAME=Makazi AI
